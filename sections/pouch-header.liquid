{{ 'pouch-header.css' | asset_url | stylesheet_tag }}

<div class="pouch-header-wrapper {% if section.settings.enable_transparent_on_index and template.name == 'index' %}pouch-header--transparent{% endif %}" id="pouch-header">
  {%- if section.settings.announcement_text != blank -%}
    <div class="pouch-announcement">
      {{ section.settings.announcement_text }}
    </div>
  {%- endif -%}

  <header class="pouch-main-header">
    <a href="{{ routes.root_url }}" class="pouch-header__logo">
      {{ shop.name | upcase }}
    </a>

    <nav class="pouch-header__nav-pill">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}" class="pouch-header__nav-link">
          {{ link.title | upcase }}
        </a>
      {%- endfor -%}
    </nav>

    <div class="pouch-header__icons">
      <a href="{{ routes.search_url }}" class="pouch-header__icon" aria-label="Search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </a>
      
      <span class="pouch-header__icon pouch-header__lang" style="font-size: 13px; font-weight: 600;">EN</span>

      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="pouch-header__icon" aria-label="Account">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="pouch-header__icon" id="cart-icon-bubble" aria-label="Cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
        <span class="pouch-header__cart-count">{{ cart.item_count }}</span>
      </a>
    </div>
  </header>
</div>

<script>
  window.addEventListener('scroll', () => {
    const header = document.getElementById('pouch-header');
    if (window.scrollY > 50) {
      header.classList.add('pouch-header--scrolled');
      if (header.classList.contains('pouch-header--transparent')) {
        header.classList.remove('pouch-header--transparent');
      }
    } else {
      header.classList.remove('pouch-header--scrolled');
      if ({{ section.settings.enable_transparent_on_index | json }} && {{ template.name | json }} === 'index') {
        header.classList.add('pouch-header--transparent');
      }
    }
  });
</script>

{% schema %}
{
  "name": "Pouch Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement Text",
      "default": "FREE SHIPPING ON ORDERS OVER $100"
    },
    {
      "type": "checkbox",
      "id": "enable_transparent_on_index",
      "label": "Transparent on Homepage",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Pouch Header"
    }
  ]
}
{% endschema %}
